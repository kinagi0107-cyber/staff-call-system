{
  "name": "staff-call-system",
  "version": "1.0.0",
  "description": "QR code-based staff calling system",
  "type": "module",
  "main": "dist/server.js",
  "scripts": {
    "dev": "node --loader tsx server.ts",
    "build": "tsc && esbuild dist/server.js --bundle --platform=node --outfile=dist/server-bundle.js",
    "start": "node dist/server-bundle.js",
    "dev:simple": "tsx server.ts"
  },
  "dependencies": {
    "express": "^4.18.2",
    "cors": "^2.8.5",
    "sqlite3": "^5.1.6",
    "uuid": "^9.0.0",
    "dotenv": "^16.0.3"
  },
  "devDependencies": {
    "typescript": "^5.0.0",
    "@types/express": "^4.17.17",
    "@types/node": "^20.0.0",
    "@types/uuid": "^9.0.0",
    "tsx": "^3.12.7",
    "esbuild": "^0.17.0"
  }
}
